              "listen": "prerequest",
              "script": {
                "exec": [
                  "// #6: openAccount 同時建立登入帳號，username 必須唯一 → 動態產生避免重跑撞名",
                  "pm.variables.set('dynUser', 'pmuser' + Date.now().toString().slice(-7));",
                  "// #5: 每電話每類型限一戶（非 CLOSED）→ 動態電話避免重跑撞『同電話同類型』",
                  "pm.variables.set('dynPhone', '09' + Date.now().toString().slice(-8));"
                ],
                "type": "text/javascript"
