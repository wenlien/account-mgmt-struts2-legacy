{
  "info": {
    "name": "Account Management Struts2 Legacy",
    "description": "Postman collection for the Struts2 + Spring 4 + Hibernate 4 legacy account management app.\n\nPrerequisites:\n- App running on {{baseUrl}} (default: http://localhost:8080)\n- MySQL up with seed data (A001 balance=1000.00)\n- .env configured with ADMIN_USERNAME/ADMIN_PASSWORD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/account-mgmt-struts2-legacy",
      "type": "string"
    },
    {
      "key": "adminUsername",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "admin1234",
      "type": "string"
    },
    {
      "key": "testAccountNo",
      "value": "A001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Spring Security form-based login",
      "item": [
        {
          "name": "Login (form-based)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login redirects (302 or 200)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('No login error in response', function () {",
                  "    pm.expect(pm.response.text()).to.not.include('Bad credentials');",
                  "    pm.expect(pm.response.text()).to.not.include('login_error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "{{adminUsername}}" },
                { "key": "password", "value": "{{adminPassword}}" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "description": "Account CRUD operations (Struts2 .action endpoints)",
      "item": [
        {
          "name": "List all accounts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains account data', function () {",
                  "    pm.expect(pm.response.text()).to.include('A001');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/accountList.action",
              "host": ["{{baseUrl}}"],
              "path": ["accountList.action"]
            }
          }
        },
        {
          "name": "Add account (show form)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/addAccount.action",
              "host": ["{{baseUrl}}"],
              "path": ["addAccount.action"]
            }
          }
        },
        {
          "name": "Save new account",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.variables.set('dynamicAcctNo', 'T' + Date.now().toString().slice(-5));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Redirects to account list (200 or 302)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "account.accountNo", "value": "{{dynamicAcctNo}}" },
                { "key": "account.ownerName", "value": "Test User" },
                { "key": "account.balance", "value": "0.00" },
                { "key": "account.status", "value": "ACTIVATED" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/saveAccount.action",
              "host": ["{{baseUrl}}"],
              "path": ["saveAccount.action"]
            }
          }
        },
        {
          "name": "Edit owner form (central, admin, load)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 (form loaded)', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/editOwnerForm.action?targetUsername=alice",
              "host": ["{{baseUrl}}"],
              "path": ["editOwnerForm.action"],
              "query": [
                { "key": "targetUsername", "value": "alice" }
              ]
            }
          }
        },
        {
          "name": "Update owner name (central, admin) — item3",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Redirects to account list (302)', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
                  "});",
                  "",
                  "pm.test('No actionError in response', function () {",
                  "    pm.expect(pm.response.text()).to.not.include('actionError');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "targetUsername", "value": "alice" },
                { "key": "displayName", "value": "Alice Chen" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/updateOwner.action",
              "host": ["{{baseUrl}}"],
              "path": ["updateOwner.action"]
            }
          }
        }
      ]
    },
